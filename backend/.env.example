# Database (Neon PostgreSQL)
# Format: postgresql://username:password@host/database?sslmode=require
# Get your connection string from Neon dashboard
DATABASE_URL="postgresql://username:password@ep-cool-region.aws.neon.tech/database?sslmode=require"

# JWT Secret - GENERATE A SECURE RANDOM KEY FOR PRODUCTION
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="b4dfc0c8c36bc559fba95c86afd5217e719cd12cc74b82083099a12611d3ad86"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="production"

# CORS - CHANGE TO YOUR FRONTEND DOMAIN IN PRODUCTION
CORS_ORIGIN="https://your-frontend-domain.com"
